{
  "name": "goal-os",
  "version": "1.0.0",
  "description": "a smart todo app for professionals",
  "license": "ISC",
  "author": "",
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "tsc -p tsconfig.electron.build.json && concurrently -k \"vite\" \"tsc -p tsconfig.electron.build.json --watch\" \"wait-on http://localhost:3000 && env -u ELECTRON_RUN_AS_NODE ELECTRON_DEV=1 electron .\"",
    "build": "vite build && tsc -p tsconfig.electron.build.json",
    "start": "env -u ELECTRON_RUN_AS_NODE electron .",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "package": "npm run build && electron-builder",
    "icons:generate": "node scripts/generate-icons.js",
    "db:generate": "drizzle-kit generate",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "build": {
    "appId": "com.goalos.app",
    "productName": "GoalOS",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "icon": "build/icon.png",
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ],
    "compression": "maximum",
    "electronLanguages": [
      "en"
    ],
    "files": [
      "dist/**/*",
      "package.json",
      "!**/*.{md,markdown,ts,tsx,map,d.ts}",
      "!**/node_modules/@types/**",
      "!**/node_modules/better-sqlite3/{deps,src}/**",
      "!**/node_modules/better-sqlite3/build/{Release/obj,Makefile,*.mk,*.Makefile,binding.Makefile,config.gypi,*.o,*.a}/**",
      "!**/node_modules/better-sqlite3/build/Release/obj/**",
      "!**/node_modules/active-win/{src,build}/**",
      "!**/node_modules/active-win/lib/binding/napi-6-darwin-unknown-x64/**",
      "!**/node_modules/active-win/lib/windows*",
      "!**/node_modules/active-win/lib/linux.js",
      "!**/node_modules/{README,CHANGELOG,LICENSE,LICENCE}*",
      "!**/node_modules/*/{test,tests,__tests__,docs,doc,example,examples}/**"
    ],
    "asar": true,
    "asarUnpack": [
      "**/node_modules/better-sqlite3/build/Release/*.node",
      "**/node_modules/better-sqlite3/bin/**/*.node",
      "**/node_modules/active-win/**/*.node",
      "**/node_modules/active-win/main"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.png",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "icon": "build/icon.png",
      "target": "nsis"
    },
    "linux": {
      "icon": "build/icon.png",
      "target": "AppImage"
    }
  },
  "dependencies": {
    "active-win": "^8.2.1",
    "better-sqlite3": "^12.6.2",
    "drizzle-orm": "^0.45.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.3",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.9",
    "electron": "^43.1.0",
    "electron-builder": "^26.8.1",
    "lucide-react": "^1.24.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "wait-on": "^9.0.4",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  }
}
